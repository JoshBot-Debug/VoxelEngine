{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Compile Shaders",
      "type": "shell",
      "command": "bash compileShaders.sh",
      "problemMatcher": []
    },
    {
      "label": "Build Debug",
      "type": "shell",
      "command": "cmake -B build -DCMAKE_BUILD_TYPE=Debug && cmake --build build",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ],
      "dependsOn": [
        "Compile Shaders"
      ]
    },
    {
      "label": "Build Debug \\w STL",
      "type": "shell",
      "command": "cmake -B build -DCMAKE_BUILD_TYPE=Debug -DENABLE_STL_DEBUG=ON && cmake --build build",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ],
      "dependsOn": [
        "Compile Shaders"
      ]
    },
    {
      "label": "Clear Logs",
      "type": "shell",
      "command": "rm -r ./logs/*",
      "problemMatcher": []
    },
    {
      "label": "Build Release",
      "type": "shell",
      "command": "cmake -B build -DCMAKE_BUILD_TYPE=Release && cmake --build build",
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": [
        "$gcc"
      ],
      "dependsOn": [
        "Compile Shaders"
      ]
    },
    {
      "label": "Build Release \\w Debug Symbols",
      "type": "shell",
      "command": "cmake -B build -DCMAKE_BUILD_TYPE=RelWithDebInfo && cmake --build build",
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": [
        "$gcc"
      ],
      "dependsOn": [
        "Compile Shaders"
      ]
    },
    {
      "label": "valgrind",
      "type": "shell",
      "command": "valgrind",
      "args": [
        "--leak-check=full",
        "--track-origins=yes",
        "${workspaceFolder}/build/Kitagawa"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "dependsOn": [
        "Build Debug"
      ],
      "problemMatcher": [
        "$gcc"
      ],
      "presentation": {
        "reveal": "always",
        "clear": true,
        "panel": "dedicated",
        "showReuseMessage": false
      },
    },
    {
      "label": "renderdoc",
      "type": "shell",
      "command": "renderdoccmd",
      "args": [
        "capture",
        "--working-dir",
        "${workspaceFolder}",
        "${workspaceFolder}/build/Kitagawa"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ],
      "dependsOn": [
        "Build Debug"
      ],
      "presentation": {
        "reveal": "always",
        "clear": true,
        "panel": "dedicated",
        "showReuseMessage": false
      }
    }
  ]
}
