uint MAX_LIGHT_SIZE=(worldSize/16);

// Allows us to peak inside the box
Ray generateRay(vec2 uv,bool peak){
  vec2 ndc=uv*2.-1.;
  vec4 rayClip=vec4(ndc,0.,1.);
  vec4 rayView=camera.inverseProjection*rayClip;
  rayView/=rayView.w;
  
  vec3 localOrigin=vec3(0.);
  vec3 localDir=normalize(vec3(rayView));
  
  vec3 worldOrigin=(camera.inverseView*vec4(localOrigin,1.)).xyz;
  vec3 worldDir=normalize((camera.inverseView*vec4(localDir,0.)).xyz);
  
  if(peak)
  {
    float size=float(worldSize);
    vec3 worldMin=vec3(1.1);
    vec3 worldMax=vec3(size-1.1);
    float tMin=0.;
    
    bool outside=intersectAABB(worldOrigin,worldDir,worldMin,worldMax,tMin);
    
    vec3 start=outside?worldOrigin+worldDir*max(tMin,0.):worldOrigin;
    
    return Ray(start,worldDir);
  }
  
  return Ray(worldOrigin,worldDir);
}

